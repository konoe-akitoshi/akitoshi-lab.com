---
import Timeline from './svelte/Timeline.svelte';
import Environment from './Environment.astro';
import Affiliated from './Affiliated.astro';
import Image from 'astro/components/Image.astro';
import Badge1 from '../assets/img/badge/dell-genai-foundations.webp';
import Badge2 from '../assets/img/badge/dell-security-foundations-2024.webp';

const tabs = [
  { id: 'profile', label: 'Profile', icon: 'i-material-symbols-light-person-outline-rounded' },
  { id: 'affiliated', label: 'Affiliated', icon: 'i-material-symbols-light-domain' },
  { id: 'timeline', label: 'Timeline', icon: 'i-material-symbols-light-co-present-outline-rounded' },
  { id: 'environment', label: 'Environment', icon: 'i-material-symbols-light-shield-with-house-outline-rounded' },
];
---

<div>
  <nav class="flex border-b-2 border-gray-200 mb-6" id="tab-bar">
    {tabs.map((tab) => (
      <button
        class:list={[
          'tab-item flex-1 flex items-center justify-center gap-1.5 py-3 px-4 border-none bg-transparent text-gray-400 text-sm font-medium cursor-pointer border-b-2 border-transparent -mb-[2px] transition-colors duration-150 whitespace-nowrap',
          tab.id === 'profile' && 'active'
        ]}
        data-tab={tab.id}
      >
        <i class={`${tab.icon} text-lg`}></i>
        <span class="tab-label">{tab.label}</span>
      </button>
    ))}
  </nav>

  <div id="tab-profile" class="tab-panel">
    <section class="mb-10">
      <h2 class="text-3xl mb-4 flex items-center">
        <i class="i-material-symbols-light-mindfulness-outline-rounded inline-block align-middle mr-2 text-4xl"></i>
        Mind
      </h2>
      <hr class="border-gray-400 mb-4" />
      <p>好きなことをとことん極める</p>
    </section>

    <section class="mb-10">
      <h2 class="text-3xl mb-4 flex items-center">
        <i class="i-material-symbols-light-upcoming-outline-rounded inline-block align-middle mr-2 text-4xl"></i>
        Skills
      </h2>
      <hr class="border-gray-400 mb-4" />
      <p>
        <a href="https://skillicons.dev">
          <img src="https://skillicons.dev/icons?i=git,github,bitbucket,gitlab,nextjs,astro,docker,fastapi,nginx,cloudflare,grafana,cpp,vim,vscode,arduino,raspberrypi,opencv,autocad,matlab,latex,md" style="max-width:100%;height:auto;display:block;margin:0 auto;" />
        </a>
      </p>
    </section>

    <section class="mb-10">
      <h2 class="text-3xl mb-4 flex items-center">
        <i class="i-material-symbols-light-id-card-outline-rounded inline-block align-middle mr-2 text-4xl"></i>
        資格
      </h2>
      <hr class="border-gray-400 mb-4" />
      <h3 class="text-xl mb-2">認定資格</h3>
      <a href="https://www.credly.com/badges/dc1e577a-c863-4c11-8377-b51780f429ec/public_url" class="btn inline-flex items-center p-2">
        <Image src={Badge1} width={110} densities={[1, 2]} alt="Badge1" />
      </a>
      <a href="https://www.credly.com/badges/6ff7b8a5-c4c8-4d1d-a683-071162cb3a5f/public_url" class="btn inline-flex items-center p-2">
        <Image src={Badge2} width={110} densities={[1, 2]} alt="Badge2" />
      </a>
      <p>CCNA CyberOps Associate 2024 修了</p>
      <h3 class="text-xl mb-2">国家資格</h3>
      <p>第四級アマチュア無線技士</p>
    </section>
  </div>

  <div id="tab-affiliated" class="tab-panel" style="display:none;">
    <Affiliated />
  </div>

  <div id="tab-timeline" class="tab-panel" style="display:none;">
    <Timeline client:visible />
  </div>

  <div id="tab-environment" class="tab-panel" style="display:none;">
    <Environment />
  </div>
</div>

<style>
  .tab-item:hover {
    color: #4b5563;
  }
  .tab-item.active {
    color: #111827;
    border-bottom-color: #111827;
  }
  @media (max-width: 480px) {
    .tab-label {
      display: none;
    }
    .tab-item {
      padding: 12px 8px;
    }
    .tab-item i {
      font-size: 22px;
    }
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const buttons = document.querySelectorAll<HTMLButtonElement>('#tab-bar .tab-item');
    const panels = document.querySelectorAll<HTMLElement>('.tab-panel');

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const id = btn.dataset.tab;
        buttons.forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');
        panels.forEach((p) => {
          p.style.display = p.id === `tab-${id}` ? '' : 'none';
        });
      });
    });
  });
</script>
