---
import { Image } from 'astro:assets';
const galleryImages = import.meta.glob('../assets/img/gallery/*.{webp,jpg,jpeg,png}', { eager: true });
let slideImages = Object.values(galleryImages).map((img: any) => img.default);

// シャッフル関数
function shuffle<T>(array: T[]): T[] {
  for (let i = array.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [array[i], array[j]] = [array[j], array[i]];
  }
  return array;
}
// ランダムで最大10枚だけ使う
slideImages = shuffle(slideImages).slice(0, 10);

// クライアントサイドで使用する画像パスリスト
const slidePaths = slideImages.map((img: any) => img.src);
---

<div id="bg-slideshow" data-slides={JSON.stringify(slidePaths)}>
  <Image
    id="bg-slide-img-1"
    src={slideImages[0]}
    alt=""
    width={slideImages[0]?.width}
    height={slideImages[0]?.height}
    class="bg-slide-img active"
    loading="eager"
    decoding="async"
    fetchpriority="high"
  />
  <Image
    id="bg-slide-img-2"
    src={slideImages[1] || slideImages[0]}
    alt=""
    width={(slideImages[1] || slideImages[0])?.width}
    height={(slideImages[1] || slideImages[0])?.height}
    class="bg-slide-img"
    loading="lazy"
    decoding="async"
  />
  <!-- インジケーター -->
  <div id="bg-slideshow-indicator">
    {slideImages.map((_, i) => (
      <div class="indicator-bar" id={`indicator-bar-${i}`}></div>
    ))}
  </div>
</div>

<style>
  #bg-slideshow-indicator {
    position: fixed;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 12px;
    z-index: 1;
    pointer-events: none;
  }
  .indicator-bar {
    width: 24px;
    height: 2px;
    background: rgba(255,255,255,0.18);
    border-radius: 1px;
    overflow: hidden;
    position: relative;
    transition: background 0.3s;
  }
  .indicator-bar.active {
    background: rgba(255,255,255,0.45);
  }
  .indicator-bar .progress {
    display: block;
    height: 100%;
    background: rgba(255,255,255,0.7);
    border-radius: 1px;
    width: 0%;
  }
  .bg-slide-img {
    width: 100vw;
    height: 100vh;
    object-fit: cover;
    position: fixed;
    top: 0;
    left: 0;
    z-index: -2;
    opacity: 0;
    transition: opacity 2s cubic-bezier(.4,0,.2,1);
    pointer-events: none;
  }
  .bg-slide-img.active {
    z-index: -1;
    opacity: 1;
  }
</style>

<script is:inline>
  (function() {
    const container = document.getElementById('bg-slideshow');
    const slides = JSON.parse(container.dataset.slides || '[]');
    if (slides.length === 0) return;

    const img1 = document.getElementById('bg-slide-img-1');
    const img2 = document.getElementById('bg-slide-img-2');
    const duration = 10000;
    let current = 0;

    function updateIndicator(index) {
      for (let i = 0; i < slides.length; i++) {
        const bar = document.getElementById('indicator-bar-' + i);
        if (!bar) continue;
        bar.classList.toggle('active', i === index);
        bar.innerHTML = '';
        if (i === index) {
          const progress = document.createElement('span');
          progress.className = 'progress';
          progress.style.animation = 'progressBarAnim ' + duration + 'ms linear forwards';
          bar.appendChild(progress);
        }
      }
    }

    // プログレスバーアニメーションを動的に追加
    if (!document.getElementById('slideshow-keyframes')) {
      const style = document.createElement('style');
      style.id = 'slideshow-keyframes';
      style.textContent = '@keyframes progressBarAnim { from { width: 0%; } to { width: 100%; } }';
      document.head.appendChild(style);
    }

    // 初期表示
    updateIndicator(current);

    // 次の画像をプリロード
    function preloadNext(index) {
      const nextIndex = (index + 1) % slides.length;
      const preloadImg = new Image();
      preloadImg.src = slides[nextIndex];
    }

    preloadNext(current);

    setInterval(function() {
      current = (current + 1) % slides.length;
      updateIndicator(current);

      // 現在activeでない方の画像を更新してactiveにする
      if (img1.classList.contains('active')) {
        img2.src = slides[current];
        img2.classList.add('active');
        img1.classList.remove('active');
      } else {
        img1.src = slides[current];
        img1.classList.add('active');
        img2.classList.remove('active');
      }

      // 次の画像をプリロード
      preloadNext(current);
    }, duration);
  })();
</script>
