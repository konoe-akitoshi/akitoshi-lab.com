---
import Layout from "../layouts/Layout.astro";
import GalleryComponent from "../components/svelte/Gallery.svelte";

// Progressive AVIF画像をpublic/から直接取得（Astroの再エンコードをバイパス）
// Progressive AVIFは1/8→1/2→1/1の3レイヤー構成で、サムネイル不要
const galleryImages = [
  { src: '/img/gallery/img1.avif', title: 'img1' },
  { src: '/img/gallery/img2.avif', title: 'img2' },
  { src: '/img/gallery/img3.avif', title: 'img3' },
  { src: '/img/gallery/img4.avif', title: 'img4' },
  { src: '/img/gallery/木の中の氷.avif', title: '木の中の氷' },
  { src: '/img/gallery/樹氷.avif', title: '樹氷' },
  { src: '/img/gallery/港.avif', title: '港' },
];

// シャッフル
const shuffledImages = [...galleryImages].sort(() => Math.random() - 0.5);
---

<Layout
  title="Gallery | Akitoshi Lab."
  description="様々な作品を展示しています。"
  ogImage="/img/OGP.webp"
  bodyClass="m-0 p-0 font-sans overflow-x-hidden bg-background text-text"
  useMainWrapper={false}
>
  <div class="gallery-page max-w-5xl mx-auto py-10 px-2 sm:px-4">
    <div class="gallery-header pt-2 pb-4 text-center">
      <h2 class="text-2xl font-bold uppercase tracking-wider mb-2 text-[#232425]">GALLERY</h2>
      <div class="w-24 h-[2px] bg-gray-200 rounded mx-auto mb-2"></div>
      <p class="text-[#A0A0A0] text-xs mb-0">作品・風景・記録などのフォトギャラリー</p>
    </div>
    <GalleryComponent client:load images={shuffledImages} />
  </div>
</Layout>

<style>
  html, body {
    overflow-x: hidden;
    max-width: 100vw;
  }
  .gallery-page {
    width: 100%;
    min-height: 100vh;
    background: #FAFAFA;
    overflow-x: hidden;
    max-width: 100vw;
    box-sizing: border-box;
  }
</style>
