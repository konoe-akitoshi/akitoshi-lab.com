---
import Layout from '../layouts/Layout.astro';
import BackgroundSlideshow from '../components/svelte/BackgroundSlideshow.svelte';
import { Image } from 'astro:assets';
import Avatar from '../assets/img/avatar.webp';

// Progressive AVIF画像をpublic/から直接取得（Astroの再エンコードをバイパス）
const galleryImagePaths = [
  '/img/gallery/img1.avif',
  '/img/gallery/img2.avif',
  '/img/gallery/img3.avif',
  '/img/gallery/img4.avif',
  '/img/gallery/木の中の氷.avif',
  '/img/gallery/樹氷.avif',
  '/img/gallery/港.avif',
];

// シャッフル
let slideImages = [...galleryImagePaths];
for (let i = slideImages.length - 1; i > 0; i--) {
  const j = Math.floor(Math.random() * (i + 1));
  [slideImages[i], slideImages[j]] = [slideImages[j], slideImages[i]];
}
---

<Layout
  title="Home | Akitoshi Lab."
  description="ロボットが大好きな大学生です．思ったことや日常の出来事をつぶやきます．たまに技術．"
  ogImage="/img/OGP.webp"
  canonicalUrl="https://akitoshi-lab.com/"
  useHeader={false}
  useFooter={false}
  useMainWrapper={false}
  bodyClass="m-0 p-0 font-mono bg-black overflow-x-hidden overflow-y-auto"
>
  <link rel="preload" href={Avatar.src} as="image" slot="preload" />
  <!-- Progressive AVIFはpreloadしない（プログレッシブ表示が無効になるため） -->

  <BackgroundSlideshow images={slideImages} client:load />
  
  <header class="fixed top-0 w-full text-left bg-transparent p-4 lg:p-8 z-1000 grid place-items-start">
    <a href="https://akitoshi-lab.com/" class="text-white no-underline text-base lg:text-lg">
      <h1 class="my-1.5 text-3xl sm:text-4xl font-bold">Akitoshi Lab.</h1>
    </a>
  </header>

    <div class="intro-link fixed top-1/2 right-1/2 transform translate-x-1/2 -translate-y-1/2 bg-black/50 p-3 rounded-lg text-center w-11/12 max-w-md mx-auto lg:top-1/2 lg:right-4 lg:left-auto lg:-translate-y-1/2 lg:translate-x-0 lg:w-1/4 lg:p-5 z-1001">
      <h1 class="text-white text-lg mb-3 break-words lg:text-2xl lg:mb-5">Hi👋 I'm Akitoshi Saeki.</h1>
      <a href="/about" class="btn-secondary inline-flex items-center justify-start gap-2 no-underline border-none p-3 rounded-lg cursor-pointer mb-2 w-full box-border transition-colors duration-300 focus:outline-none lg:gap-4 lg:p-5 lg:mb-4">
        <Image 
          src={Avatar} 
          width={32} 
          height={32}
          densities={[1, 2]} 
          alt="avatar" 
          class="w-6 h-6 rounded-lg lg:w-8 lg:h-8" 
          loading="eager"
        />
        About me
      </a>
      <a href="https://blog.akitoshi-lab.com/" class="btn-secondary inline-flex items-center justify-start gap-2 no-underline border-none p-3 rounded-lg cursor-pointer mb-2 w-full box-border transition-colors duration-300 focus:outline-none lg:gap-4 lg:p-5 lg:mb-4">
        <div class="i-carbon:blog w-6 h-6 lg:w-8 lg:h-8" style="color: black;"></div>
        Blog
      </a>
      <a href="/works" class="btn-secondary inline-flex items-center justify-start gap-2 no-underline border-none p-3 rounded-lg cursor-pointer mb-2 w-full box-border transition-colors duration-300 focus:outline-none lg:gap-4 lg:p-5 lg:mb-4">
        <div class="i-codicon:tools w-6 h-6 lg:w-8 lg:h-8" style="color: black;"></div>
        Works
      </a>
      <a href="/gallery" class="btn-secondary inline-flex items-center justify-start gap-2 no-underline border-none p-3 rounded-lg cursor-pointer mb-2 w-full box-border transition-colors duration-300 focus:outline-none lg:gap-4 lg:p-5 lg:mb-4">
        <div class="i-system-uicons:picture w-6 h-6 lg:w-8 h-8" style="color: black;"></div>
        Gallery
      </a>
    </div>

    <footer class="fixed bottom-0 w-full text-left bg-transparent p-4 lg:p-8 z-1000 text-gray-500 grid place-items-start">
      <p class="my-0">&copy; 2024 Akitoshi Saeki</p>
    </footer>
</Layout>
